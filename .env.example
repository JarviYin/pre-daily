# ─────────────────────────────────────────────────────────────
# Prediction Daily (预测市场中文早报) — environment template
# Copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Postgres (Neon recommended; any Postgres connection string works)
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# Per-market zh analysis LLM (OpenAI-compatible). Default: DeepSeek.
# DeepSeek: base=https://api.deepseek.com  model=deepseek-chat (V3) / deepseek-reasoner
LLM_API_KEY="sk-..."
LLM_BASE_URL="https://api.deepseek.com"
LLM_MODEL="deepseek-chat"

# Optional: route the daily cross-market summary to a stronger model.
# If unset, the summary uses LLM_* above. To use Claude, set these:
# SUMMARY_API_KEY="sk-ant-..."
# SUMMARY_BASE_URL="https://api.anthropic.com/v1"   # via OpenAI-compat shim, or leave to reuse LLM_*
# SUMMARY_MODEL="claude-..."

# Protects the cron refresh endpoint. Generate: openssl rand -hex 32
CRON_SECRET="change-me-to-a-long-random-string"

# Public site URL (used for canonical/OG/sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL="https://www.pre-daily.com"

# Telegram subscribe entry point shown on the web (point at a public channel).
NEXT_PUBLIC_TELEGRAM_URL="https://t.me/predailybot"

# How many top markets per daily edition.
TOP_N_MARKETS="10"

# Telegram daily broadcast (P3) + failure alerts. From @BotFather.
# The bot must be an ADMIN of the channel it posts to.
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHANNEL_ID=""        # public daily push, e.g. "@prediction_daily" or -100…
# TELEGRAM_ALERT_CHAT_ID=""     # private chat/group for cron failure alerts
